APP_ENV=development
JWT_SECRET_KEY=dev-local-change-me

# PostgreSQL lokal via docker-compose.local.yml
DB_USER=life_os
DB_PASSWORD=life_os_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=life_os

# CORS frontend lokal
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Local development defaults
RATE_LIMIT_ENABLED=false
AUTO_DB_BOOTSTRAP=true

# PostgreSQL uses Alembic by default.
# Use legacy_sql only if you intentionally want the old SQL migration files.
DB_MIGRATION_MODE=alembic

# Production/Hugging Face + Supabase example:
# APP_ENV=production
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres
# JWT_SECRET_KEY=replace-with-at-least-32-random-characters
# CORS_ORIGINS=https://your-frontend.vercel.app
# AUTO_DB_BOOTSTRAP=true
# TRUST_PROXY_HEADERS=true
